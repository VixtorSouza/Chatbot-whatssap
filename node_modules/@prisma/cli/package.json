    "@prisma/compute-sdk": "^0.28.0",
    "@prisma/credentials-store": "^7.8.0",
    "@prisma/management-api-sdk": "^1.37.0",
    "better-result": "^2.9.2",
    "colorette": "^2.0.20",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "magicast": "^0.5.3",
    "open": "^11.0.0",
    "string-width": "^8.2.1",
    "strip-ansi": "^7.2.0",
    "wrap-ansi": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
