{
  "name": "@prisma/management-api-sdk",
  "version": "1.41.0",
  "description": "TypeScript SDK for the Prisma Developer Platform Management API",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prisma/pdp-control-plane.git",
    "directory": "packages/management-api-sdk"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "import": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "check:types": "tsc --noEmit",
    "test": "vitest",
    "generate-api-client": "openapi-typescript https://api.prisma.io/v1/doc --output ./src/api.d.ts",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "openapi-fetch": "0.14.0"
  },
  "devDependencies": {
    "openapi-typescript": "7.10.1",
    "tsdown": "^0.12.2"
  },
  "keywords": [
    "prisma",
    "api",
    "sdk",
    "management",
    "typescript"
  ]
}
